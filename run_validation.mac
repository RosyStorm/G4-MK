#===============================#
# Cell geometry validation run  #
# 任务1.1：同心球细胞几何验证    #
# 质子穿过细胞核，确认几何/打分正确 #
#===============================#

/control/verbose 0
/run/verbose 2
/tracking/verbose 0

/random/setSeeds 102 001

###########################
### SETUP CONFIGURATION ###
###########################
### 同心球几何：World(水盒) -> Cell(R_cell) -> Nucleus(R_n)
### maxRange 决定细胞外水层厚度(次级电子平衡)；世界半边长 = R_cell + maxRange
/mygeom/maxRange        49. um
/mygeom/material        G4_WATER
/mygeom/cellRadius      10. um
/mygeom/nucleusRadius    8. um
/mygeom/siteRadius      0.5 um


####################
### PHYSICS LIST ###
####################
/physics/addPhysics dna_opt2

##################################################
### PRODUCTION CUT DEFINITIONS (for condensed) ###
##################################################
/run/setCutForAGivenParticle gamma   0.01 um
/run/setCutForAGivenParticle e-      0.01 um
/run/setCutForAGivenParticle e+      0.01 um
/run/setCutForAGivenParticle proton  0.01 um

######################
### INITIALIZATION ###
######################
/run/numberOfThreads 8
/run/initialize

######################################################
### BEAM PROPERTIES (must be after Initialization) ###
######################################################
### 质子从 z0=-50.99 um 出发(世界半边长59um内)，到达核中心约20 MeV
/gun/particle       proton
/gun/energy         20.13 MeV  ## Energy compensation from (dE/dz)*Z0
/beam/position/Z0   -50.99 um

#######################
### PRODUCTION CUTS ###
#######################
/run/particle/applyCuts true e-
/run/particle/applyCuts true gamma


/run/beamOn 500
